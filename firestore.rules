rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Filtro Backend: Retorna falso (Permission Denied) si hay coincidencias con palabras prohibidas
    function isCleanText(text) {
      // Ignoramos si no hay texto. Si lo hay, comprobamos usando matches y una regex estricta.
      return text == null || !text.matches('(?i).*(asesinar|asesinato|cabr[oó]n|caca|cago|cerote|chinga|chingada|chingar|co[nñ]o|cojones|culo|droga|est[uú]pido|follar|gilipollas|idiota|hijo de puta|hijueputa|hostia|joder|jodido|marica|maric[oó]n|matar|mierda|mrd|odio|paja|pajero|pendejo|perra|pinche|polla|porno|pornograf[ií]a|prostituta|puta|puto|retrasado|semen|spam|suicidar|suicidio|teta|violaci[oó]n|violencia|zorra|scheisse|ficken|arschloch|hure|schlampe|wichser|fotze|bastard|verdammt|missgeburt|nutte|schweinehund|dummkopf|kacke|depp|sau|trottel|arsch|pisser|luder|miststueck|penner|schwachkopf).*');
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin');
    }
    
    match /historial_perfiles/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // CAPA 1 SEGURIDAD: Gatillo backend estricto usando expresión regular para bloquear texto inapropiado
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && isCleanText(request.resource.data.get('titulo', '')) 
                    && isCleanText(request.resource.data.get('descripcion', ''));
      allow update: if request.auth != null 
                    && isCleanText(request.resource.data.get('titulo', '')) 
                    && isCleanText(request.resource.data.get('descripcion', ''));
      allow delete: if request.auth != null;
    }

    // Permitir acceso básico al resto de colecciones necesarias para el funcionamiento de la app
    match /{collectionName}/{docId} {
      allow read, write: if request.auth != null && collectionName in ['notificaciones', 'reportes_quedadas', 'avisos_modificaciones'];
    }
  }
}
